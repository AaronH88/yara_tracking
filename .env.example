# ── Project identity ───────────────────────────────────────────────────────────
# Used by podman-compose to namespace containers and networks.
# Each worktree gets a unique value — set automatically by init-git-worktree.sh
PODMAN_PROJECT=myproject

# Worktree slot — set automatically by init-git-worktree.sh
# 0 = main repo, 1+ = worktrees (each slot offsets ports by +100)
NEXUS_SLOT=0

# ── Service ports ──────────────────────────────────────────────────────────────
# Offset these by NEXUS_SLOT * 100 in worktrees to avoid collisions.
# These are forwarded wholesale into the claude sandbox container via --env-file.
DB_PORT=5432
CACHE_PORT=6379
API_PORT=8000
UI_PORT=8080

# ── Database ───────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=admin
DB_PASSWORD=admin
DB_NAME=myproject_db

# ── Cache ──────────────────────────────────────────────────────────────────────
CACHE_HOST=localhost
CACHE_PASSWORD=secret

# ── API ────────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
LOG_LEVEL=DEBUG

# ── External API keys ──────────────────────────────────────────────────────────
# These are forwarded into the claude sandbox so Claude can call external services
# if your project needs them. Remove any your project does not use.
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# ── Claude sandbox overrides (optional) ───────────────────────────────────────
# Uncomment to override defaults in run-claude-sandbox.sh
# CLAUDE_SANDBOX_IMAGE=localhost/claude-sandbox:latest
# CLAUDE_SANDBOX_MEMORY=4g
# CLAUDE_SANDBOX_CPUS=2