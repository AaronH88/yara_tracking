# ── Project identity ───────────────────────────────────────────────────────────
# Used by podman-compose to namespace containers and networks.
# Each worktree gets a unique value — set automatically by init-git-worktree.sh
PODMAN_PROJECT=yara_tracking

# Worktree slot — set automatically by init-git-worktree.sh
# 0 = main repo, 1+ = worktrees (each slot offsets ports by +100)
# NEXUS_SLOT=0
