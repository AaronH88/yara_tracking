# Claude Code Sandbox
# A minimal container for running Claude Code with --dangerously-skip-permissions
# safely isolated to a single worktree.
#
# Build: podman build -t claude-sandbox -f containers/claude-sandbox/Containerfile .
# Usage: tools/run-claude-sandbox.sh [--isolated] [--task "..." | --task-file <file> | --shell | --exec "..."]
#
# No CMD — the entrypoint is always driven by run-claude-sandbox.sh on the host.

FROM public.ecr.aws/docker/library/node:22-slim

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    make \
    curl \
    ca-certificates \
    bash \
    python3 \
    python3-pip \
    python3-venv \
    && rm -rf /var/lib/apt/lists/*

# Install uv (fast Python package manager used by this project)
RUN curl -LsSf https://astral.sh/uv/install.sh | bash
ENV PATH="/root/.local/bin:$PATH"

# Install Claude Code CLI globally
RUN npm install -g @anthropic-ai/claude-code

# Use existing node user (uid 1000) for Claude Code
# Claude Code refuses to run with --dangerously-skip-permissions as root
RUN mkdir -p /workspace && \
    chown -R node:node /workspace /home/node

# Set working directory — the worktree will be mounted here
WORKDIR /workspace

# Switch to non-root user
USER node