# Baby Tracker — Backend Environment Configuration
# Copy to .env and adjust as needed.

# SQLite database path (production default shown)
DATABASE_URL=sqlite+aiosqlite:////var/lib/babytracker/db.sqlite

# Comma-separated allowed CORS origins (use * for all)
CORS_ORIGINS=*

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=info
