[Unit]
Description=Baby Tracker
After=network.target

[Service]
Type=simple
User=babytracker
Group=babytracker
WorkingDirectory=/opt/babytracker/backend
Environment=DATABASE_URL=sqlite:////var/lib/babytracker/db.sqlite
Environment=STATIC_DIR=/opt/babytracker/frontend/dist
ExecStart=/opt/babytracker/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
